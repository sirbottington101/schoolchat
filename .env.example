# Database
POSTGRES_USER=schoolchat
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=schoolchat
DATABASE_URL=postgresql+asyncpg://schoolchat:CHANGE_ME_TO_A_STRONG_PASSWORD@db:5432/schoolchat

# Redis
REDIS_URL=redis://redis:6379/0

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# Encryption — generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_RANDOM_KEY

# Server
SERVER_NAME=SchoolChat
ALLOWED_ORIGINS=*
